# Production Environment Template
# Use this for your deployed backend runtime.

# Backend runtime (required)
NODE_ENV=production
PORT=8000
CORS_ORIGIN=https://your-frontend-domain.com

# Frontend public env (if frontend and API are on different domains)
# REACT_APP_API_BASE_URL=https://api.your-frontend-domain.com
# REACT_APP_RAZORPAY_KEY=rzp_live_replace_me
# Backward-compatible alias also supported:
# REACT_APP_RAZORPAY_KEY_ID=rzp_live_replace_me

# Database (required by backend)
DATABASE_URL=postgresql://user:password@your-pooler-host:6543/dbname?sslmode=require
# Optional fallback alias supported by backend/scripts
SUPABASE_DATABASE_URL=postgresql://user:password@your-pooler-host:6543/dbname?sslmode=require

# Optional cloud image storage for shared uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret
CLOUDINARY_FOLDER=thriftapp
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=your_bucket_name
AWS_REGION=us-east-1
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me
