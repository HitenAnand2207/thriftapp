# ThriftApp Environment Variables Template
# Copy this file to .env.local (for Vercel) and .env (for local development)
# Replace the placeholder values with your actual credentials

#======================================
# PRODUCTION ENVIRONMENT VARIABLES
# Required for Vercel deployment
#======================================

# Supabase Database Configuration
# Get these from your Supabase project settings → Database → Connection string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_DATABASE_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Alternative database URL (if using different provider)
DATABASE_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Cloudinary Image Hosting (Free tier available)
# Get these from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Application Settings
NODE_ENV=production
PORT=3000

# Authentication (Optional - for future use)
JWT_SECRET=your-super-secret-jwt-key-here
SESSION_SECRET=your-session-secret-here

# Payment Gateway (Optional - if using Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

#======================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# For local development only
#======================================

# When NODE_ENV=development, the app uses SQLite
# No database URL needed for local development

# Local Cloudinary settings (same as production)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key  
# CLOUDINARY_API_SECRET=your_api_secret

#======================================
# QUICK SETUP GUIDE
#======================================

# 1. SUPABASE SETUP:
#    - Go to https://supabase.com
#    - Create a new project (free tier available)
#    - Go to Settings → Database
#    - Copy the connection string
#    - Replace [PASSWORD] with your database password

# 2. CLOUDINARY SETUP:
#    - Go to https://cloudinary.com
#    - Sign up for free account
#    - Go to Dashboard
#    - Copy Cloud Name, API Key, API Secret

# 3. VERCEL DEPLOYMENT:
#    - Add these variables in Vercel dashboard
#    - Project Settings → Environment Variables
#    - Add each variable (name and value)
#    - Redeploy your application

#======================================
# SECURITY NOTES
#======================================

# ⚠️  NEVER commit this file with real values to GitHub
# ✅ Add .env* to your .gitignore
# ✅ Use strong, unique passwords
# ✅ Rotate secrets regularly
# ✅ Use different credentials for production and development