# ThriftApp Environment Template
# Copy the relevant section values into:
# - server/.env (backend)
# - .env.local (frontend)

# ======================================================
# Backend runtime (USED by server/server.js)
# ======================================================
# server/.env
PORT=8000
NODE_ENV=development
CORS_ORIGIN=
# Optional cloud image storage (if all 3 are set, backend uploads to Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder name in Cloudinary (default: thriftapp)
CLOUDINARY_FOLDER=thriftapp

# ======================================================
# Frontend runtime (USED by React app)
# ======================================================
# .env.local
# Optional. Keep empty to use relative /api calls with local proxy.
REACT_APP_API_BASE_URL=

# Optional. Used in src/utils/razorpay.js.
REACT_APP_RAZORPAY_KEY=rzp_test_replace_me
# Backward-compatible alias also supported:
# REACT_APP_RAZORPAY_KEY_ID=rzp_test_replace_me

# Optional. Only used by src/setupProxy.js in local dev.
REACT_APP_BACKEND_PORT=8000

# ======================================================
# Deployment database/runtime variables (USED by server/server.js in production)
# ======================================================
# Use your pooled Postgres URI (Neon/Supabase/etc.)
DATABASE_URL=postgresql://user:password@your-pooler-host:6543/dbname?sslmode=require
# Optional alias still supported by server/scripts
SUPABASE_DATABASE_URL=postgresql://user:password@your-pooler-host:6543/dbname?sslmode=require

# Optional platform-specific helpers
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=your_bucket_name
AWS_REGION=us-east-1
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
